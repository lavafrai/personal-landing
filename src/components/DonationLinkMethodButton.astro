---
import { Icon } from "astro-icon/components";

interface Props {
    href: string;
    label: string;
    class?: string;
    color: string;
}

const { href, label, class: className, color } = Astro.props;
---

<a href={href} target="_blank" class={className}>
    <div class="donate-button" style="margin-top: 20px;">
        <div class="donate-icon" style={`background: ${color};`}>
            <slot />
        </div>
        <div class="donate-label ml-2">
            {label}
        </div>
        <i class="las la-external-link-alt donate-label-icon"></i>
    </div>
</a>

<style>
    a {
        text-decoration: none;
        display: block;
    }

    .donate-button {
        color: #fff;
        background-color: #333;
        border-radius: 0.6rem;
        font-size: 1.4rem;
        overflow: hidden;
        display: flex;
        flex-direction: row;
        height: 3rem;
        cursor: pointer;
        transition: box-shadow 0.3s;
    }

    .donate-button:hover {
        box-shadow: 0 0.2rem 0.5rem rgba(0, 0, 0, 0.5);
    }

    .donate-icon {
        height: 100%;
        aspect-ratio: 1 / 1;
        display: block;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .donate-label {
        align-self: center;
        flex-grow: 1;
        text-align: left;
    }

    .donate-label-icon {
        align-self: center;
        margin-right: 0.5rem;
    }
</style>
