---
import Gmail from 'simple-icons-astro/Gmail';
import Telegram from 'simple-icons-astro/Telegram';
import Vk from 'simple-icons-astro/Vk';
import Discord from 'simple-icons-astro/Discord';
import GitHub from 'simple-icons-astro/Github';
---

<footer class="site-footer">
  <div class="max-w-7xl mx-auto px-4">
    <div class="footer-grid">
      <div class="footer-col">
        <p>© 2024 - lava_frai (Владимир Курдюков)<br />photos: © Владимир Курдюков</p>
      </div>

      <div class="footer-col text-center">
        <p>With <i class="fa fa-heart"></i> by. @lava_frai</p>
      </div>

      <div class="footer-col">
        <div class="social-footer">
            <a href="https://t.me/lavafrai_channel" target="_blank"><Telegram size="2rem" /></a>
            <a href="mailto:lavafrai@yandex.ru"><Gmail size="2rem" /></a>
            <!--a href="https://vk.com/lava_frai" target="_blank"><Vk size="2.5rem" /></a-->
            <a href="https://discord.com/users/677933625802489889" target="_blank"><Discord size="2rem" /></a>
            <a href="https://www.github.com/lavafrai" target="_blank"><GitHub size="2rem" /></a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    display: block;
    background-color: black;
    color: #fff;
    padding: 50px 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    align-items: center;
  }

  .footer-col p {
    padding: 15px;
    opacity: 0.8;
    color: #fff;
  }

  .social-footer {
    padding: 15px;
    display: flex;
    justify-content: center;
  }

  .social-footer a {
    color: white;
    text-decoration: none;
    padding: 0.4em;
    font-size: 1.7em;
  }

  .social-footer a:hover {
    opacity: 0.7;
    color: white;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .social-footer {
      text-align: center;
    }

    .footer-col p {
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .site-footer {
      padding-bottom: 100px;
    }

    .social-footer a {
      padding: 0.3em;
      font-size: 1.6em;
    }
  }
</style>
